<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Horas Extras · Catalina</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
<noscript><link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet"></noscript>
<style>
:root{--bg:#0c110d;--bg2:#131a14;--bg3:#1b2620;--border:rgba(163,230,53,0.08);--border2:rgba(163,230,53,0.18);--accent:#a3e635;--accent2:#65a30d;--accent3:#bef264;--glow:rgba(163,230,53,0.18);--text:#eeffd6;--text2:#7fa85a;--text3:#3d5c28;--sat:#fb923c;--sat-bg:rgba(251,146,60,0.12);--danger:#f87171;--danger-bg:rgba(248,113,113,0.10);--success:#34d399;--r:14px;--r2:10px;}
*{box-sizing:border-box;margin:0;padding:0;}
html{font-size:16px;}
body{font-family:'Nunito',-apple-system,'Helvetica Neue',Arial,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;-webkit-font-smoothing:antialiased;-webkit-tap-highlight-color:transparent;}
.splash{position:fixed;inset:0;z-index:900;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;padding:40px;transition:opacity .5s cubic-bezier(.4,0,.2,1),transform .5s cubic-bezier(.4,0,.2,1);}
.splash.gone{opacity:0;pointer-events:none;transform:scale(.96);}
.splash-ring{width:86px;height:86px;border-radius:50%;background:linear-gradient(135deg,var(--accent2),var(--accent));display:flex;align-items:center;justify-content:center;font-size:2.2rem;margin-bottom:6px;box-shadow:0 0 48px var(--glow);}
.splash-title{font-size:2rem;font-weight:900;color:var(--text);letter-spacing:-0.5px;}
.splash-sub{font-size:0.92rem;color:var(--text2);text-align:center;line-height:1.7;max-width:260px;font-weight:500;}
.splash-year{margin-top:6px;font-size:0.7rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;background:rgba(163,230,53,0.08);border:1px solid var(--border2);color:var(--accent3);padding:4px 14px;border-radius:100px;font-family:'JetBrains Mono',monospace;}
.splash-btn{margin-top:22px;background:var(--accent);color:#0c110d;border:none;border-radius:100px;padding:14px 36px;font-size:0.95rem;font-weight:800;cursor:pointer;font-family:'Nunito',inherit;box-shadow:0 4px 28px var(--glow);transition:transform .15s;}
.splash-btn:active{transform:scale(.97);}
.header{background:var(--bg2);border-bottom:1px solid var(--border);padding:14px 18px 0;position:sticky;top:0;z-index:100;}
.hdr-top{display:flex;justify-content:space-between;align-items:center;padding-bottom:14px;}
.hdr-title{font-size:0.97rem;font-weight:800;color:var(--text);letter-spacing:-0.2px;}
.hdr-sub{font-size:0.72rem;color:var(--text2);margin-top:1px;font-weight:600;}
.sync{font-size:0.68rem;font-weight:600;background:var(--bg3);color:var(--text2);padding:4px 10px;border-radius:100px;font-family:'JetBrains Mono',monospace;border:1px solid var(--border);transition:all .3s;}
.sync.ok{color:var(--success);border-color:rgba(52,211,153,.25);}
.sync.saving{color:var(--sat);border-color:rgba(251,146,60,.25);}
.sync.error{color:var(--danger);border-color:rgba(248,113,113,.25);}
.tabs{display:flex;overflow-x:auto;scrollbar-width:none;}
.tabs::-webkit-scrollbar{display:none;}
.tab{flex:1;min-width:56px;padding:9px 4px 11px;text-align:center;font-size:0.58rem;font-weight:700;color:var(--text3);cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;white-space:nowrap;text-transform:uppercase;letter-spacing:.5px;user-select:none;font-family:'Nunito',sans-serif;}
.tab .ti{font-size:1.05rem;display:block;margin-bottom:3px;filter:grayscale(1);opacity:.45;transition:all .2s;}
.tab.active{color:var(--accent);border-bottom-color:var(--accent);}
.tab.active .ti{filter:none;opacity:1;}
.content{padding:14px 13px 36px;max-width:540px;margin:0 auto;}
.panel{display:none;}
.panel.active{display:block;animation:fadeIn .22s ease;}
@keyframes fadeIn{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:none}}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:18px;margin-bottom:10px;}
.card-title{font-size:0.62rem;font-weight:800;color:var(--text3);text-transform:uppercase;letter-spacing:1.2px;margin-bottom:14px;}
.frase{position:relative;overflow:hidden;background:linear-gradient(135deg,#1a3a08 0%,#0c110d 100%);border-radius:var(--r);padding:16px 18px;margin-bottom:10px;color:var(--accent3);font-size:0.9rem;font-weight:600;line-height:1.6;border:1px solid rgba(163,230,53,0.18);}
.frase::after{content:'';position:absolute;top:-20px;right:-20px;width:80px;height:80px;border-radius:50%;background:rgba(163,230,53,0.05);}
.cal-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.cal-nav{width:32px;height:32px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r2);font-size:0.95rem;cursor:pointer;color:var(--text2);display:flex;align-items:center;justify-content:center;transition:all .15s;font-family:inherit;}
.cal-nav:active{background:var(--accent2);color:white;border-color:var(--accent2);}
.cal-month{font-size:0.9rem;font-weight:800;color:var(--text);}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;}
.cdn{text-align:center;font-size:0.55rem;font-weight:800;color:var(--text3);padding:3px 0;text-transform:uppercase;letter-spacing:.4px;}
.cd{height:36px;display:flex;align-items:center;justify-content:center;border-radius:7px;font-size:0.78rem;font-weight:500;cursor:pointer;transition:background .12s,color .12s;color:var(--text2);position:relative;}
.cd:hover:not(.empty):not(.dom):not(.feriado){background:var(--bg3);color:var(--text);}
.cd.selected{background:var(--accent)!important;color:#0c110d!important;font-weight:800;box-shadow:0 0 14px var(--glow);}
.cd.today{color:var(--accent);font-weight:700;}
.cd.today::before{content:'';position:absolute;inset:0;border:1.5px solid var(--accent);border-radius:7px;opacity:.6;}
.cd.sabado{color:var(--sat);}
.cd.dom{color:var(--text3);cursor:default;opacity:.3;}
.cd.feriado{cursor:default;color:#fca5a5!important;background:rgba(248,113,113,0.08)!important;}
.cd.feriado::before{content:'';position:absolute;inset:0;border:1px solid rgba(248,113,113,0.2);border-radius:7px;}
.cd.empty{cursor:default;}
.cd.has-reg{font-weight:700;}
.cd.has-reg::after{content:'';position:absolute;bottom:3px;left:50%;transform:translateX(-50%);width:5px;height:5px;border-radius:50%;background:var(--accent);box-shadow:0 0 7px var(--accent);}
.cd.selected.has-reg::after{background:#0c110d;box-shadow:none;}
.cd.c-quinta::after{background:#a3e635;box-shadow:0 0 8px #a3e635;}
.cd.c-recoleta::after{background:#34d399;box-shadow:0 0 8px #34d399;}
.cd.c-sar::after{background:#f472b6;box-shadow:0 0 8px #f472b6;}
.cd.c-hevia::after{background:#60a5fa;box-shadow:0 0 8px #60a5fa;}
.cd.c-petrinovic::after{background:var(--sat);box-shadow:0 0 8px var(--sat);}
.fg{margin-bottom:12px;}
.fl{font-size:0.72rem;font-weight:700;color:var(--text2);margin-bottom:6px;display:block;}
select,input[type="number"],input[type="text"]{width:100%;padding:11px 13px;background:var(--bg3);color:var(--text);border:1px solid var(--border);border-radius:var(--r2);font-size:0.88rem;font-family:'Nunito',inherit;-webkit-appearance:none;appearance:none;outline:none;transition:border-color .15s;font-weight:600;}
select:focus,input[type="number"]:focus,input[type="text"]:focus{border-color:var(--accent);}
select option{background:var(--bg2);}
.ext-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;}
.ext-btn{padding:10px;text-align:center;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r2);cursor:pointer;font-size:0.82rem;font-weight:700;color:var(--text2);transition:all .15s;font-family:'Nunito',inherit;user-select:none;}
.ext-btn.on{background:rgba(163,230,53,0.12);border-color:var(--accent);color:var(--accent);font-weight:800;}
.hdisplay{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r2);padding:14px 16px;display:flex;align-items:center;justify-content:space-between;}
.hnum{font-size:2.6rem;font-weight:900;color:var(--accent);font-family:'JetBrains Mono',monospace;letter-spacing:-2px;line-height:1;}
.hmdia{font-size:0.82rem;font-weight:700;color:var(--text);}
.hmtipo{font-size:0.68rem;color:var(--text2);margin-top:3px;font-family:'JetBrains Mono',monospace;font-weight:500;}
.hmtipo.sat{color:var(--sat);}
.hmtipo.vie{color:var(--accent3);}
.btn{display:block;width:100%;padding:13px;border:none;border-radius:var(--r2);font-size:0.92rem;font-weight:800;font-family:'Nunito',inherit;cursor:pointer;transition:all .15s;text-align:center;user-select:none;}
.btn:active{transform:scale(.98);}
.btn-primary{background:var(--accent);color:#0c110d;box-shadow:0 2px 18px var(--glow);}
.btn-ghost{background:transparent;color:var(--text2);border:1px solid var(--border);}
.btn-danger{background:var(--danger-bg);color:var(--danger);border:1px solid rgba(248,113,113,.2);}
.btn-dark{background:var(--bg3);color:var(--text);border:1px solid var(--border);}
.btn-sm{width:auto;display:inline-flex;align-items:center;gap:5px;padding:7px 13px;font-size:0.76rem;border-radius:8px;}
.btn-mt{margin-top:10px;}
.ri{padding:13px 0;border-bottom:1px solid var(--border);}
.ri:last-child{border-bottom:none;}
.ri-row{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;}
.ri-date{font-size:0.86rem;font-weight:800;color:var(--text);}
.ri-meta{display:flex;flex-wrap:wrap;align-items:center;gap:5px;margin-top:4px;}
.ri-centro{font-size:0.77rem;color:var(--text2);font-weight:600;}
.badge{font-size:0.62rem;font-weight:700;padding:2px 7px;border-radius:100px;background:rgba(163,230,53,0.1);color:var(--accent3);}
.badge.sat{background:var(--sat-bg);color:var(--sat);}
.badge.vie{background:rgba(190,242,100,0.1);color:var(--accent3);}
.ri-right{text-align:right;flex-shrink:0;}
.ri-horas{font-size:1.3rem;font-weight:900;color:var(--accent);font-family:'JetBrains Mono',monospace;}
.ri-monto{font-size:0.7rem;color:var(--text3);font-family:'JetBrains Mono',monospace;margin-top:1px;}
.ri-actions{display:flex;gap:7px;margin-top:10px;}
.ri-actions .btn{flex:1;padding:9px;font-size:0.8rem;}
.stat-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;}
.stat{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:16px 14px;text-align:center;}
.stat-num{font-size:2rem;font-weight:900;color:var(--accent);font-family:'JetBrains Mono',monospace;letter-spacing:-1px;}
.stat-lbl{font-size:0.65rem;font-weight:700;color:var(--text3);margin-top:3px;text-transform:uppercase;letter-spacing:.8px;}
.total-hero{background:linear-gradient(135deg,#1a3a08,#0c110d);border:1px solid rgba(163,230,53,0.22);border-radius:var(--r);padding:22px 18px;text-align:center;margin-bottom:10px;position:relative;overflow:hidden;}
.total-hero::before{content:'';position:absolute;top:-30px;right:-30px;width:100px;height:100px;border-radius:50%;background:rgba(163,230,53,0.05);}
.th-lbl{font-size:0.65rem;font-weight:700;color:rgba(163,230,53,0.5);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;}
.th-amt{font-size:2.5rem;font-weight:900;color:var(--accent3);font-family:'JetBrains Mono',monospace;letter-spacing:-2px;}
.th-detail{font-size:0.72rem;color:rgba(163,230,53,0.4);margin-top:6px;font-family:'JetBrains Mono',monospace;}
.cb{margin-bottom:14px;}
.cb:last-child{margin-bottom:0;}
.cb-row{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:3px;}
.cb-name{font-size:0.84rem;font-weight:700;color:var(--text);}
.cb-amt{font-size:0.84rem;font-weight:700;color:var(--accent);font-family:'JetBrains Mono',monospace;}
.cb-sub{font-size:0.7rem;color:var(--text3);margin-bottom:5px;}
.bar-bg{background:var(--bg3);border-radius:100px;height:4px;overflow:hidden;}
.bar-fill{height:100%;border-radius:100px;background:linear-gradient(90deg,var(--accent2),var(--accent));transition:width .6s cubic-bezier(.34,1.56,.64,1);}
.mes{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);margin-bottom:8px;overflow:hidden;}
.mes-hdr{padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;user-select:none;}
.mes-nombre{font-size:0.9rem;font-weight:800;color:var(--text);}
.mes-stats{font-size:0.72rem;color:var(--text3);margin-top:2px;font-family:'JetBrains Mono',monospace;}
.mes-chev{color:var(--text3);transition:transform .2s;font-size:0.75rem;margin-left:6px;}
.mes-chev.open{transform:rotate(180deg);}
.mes-body{display:none;padding:0 16px 14px;border-top:1px solid var(--border);}
.mes-body.open{display:block;}
.mes-acts{display:flex;gap:7px;margin-top:10px;flex-wrap:wrap;}
.cfg-section{padding-bottom:18px;margin-bottom:18px;border-bottom:1px solid var(--border);}
.cfg-section:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0;}
.cfg-title{font-size:0.8rem;font-weight:800;color:var(--text);margin-bottom:12px;}
.cfg-ok{margin-top:10px;padding:9px 13px;background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.2);border-radius:var(--r2);font-size:0.8rem;color:var(--success);font-weight:700;text-align:center;display:none;}
.cfg-info{margin-top:8px;padding:10px 13px;background:rgba(163,230,53,0.06);border:1px solid rgba(163,230,53,0.14);border-radius:var(--r2);font-size:0.74rem;color:var(--text2);line-height:1.6;font-weight:500;}
.cfg-tarifa-badge{display:inline-block;background:rgba(163,230,53,0.1);color:var(--accent3);font-size:0.62rem;font-weight:700;padding:2px 8px;border-radius:100px;font-family:'JetBrains Mono',monospace;margin-left:6px;}
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.65);backdrop-filter:blur(8px);z-index:500;align-items:flex-end;justify-content:center;}
.overlay.open{display:flex;}
.sheet{background:var(--bg2);border:1px solid var(--border);border-radius:20px 20px 0 0;padding:10px 20px 38px;width:100%;max-width:480px;animation:slideUp .28s cubic-bezier(.34,1.56,.64,1);}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.sheet-handle{width:36px;height:4px;background:var(--bg3);border-radius:100px;margin:0 auto 18px;}
.sheet h3{font-size:1rem;font-weight:800;color:var(--text);margin-bottom:4px;}
.sheet p{font-size:0.84rem;color:var(--text2);margin-bottom:16px;line-height:1.5;font-weight:500;}
.sheet-acts{display:flex;gap:8px;margin-top:14px;}
.sheet-acts .btn{flex:1;}
.loader{display:none;position:fixed;inset:0;background:rgba(12,17,13,.85);backdrop-filter:blur(6px);z-index:800;align-items:center;justify-content:center;flex-direction:column;gap:12px;}
.loader.show{display:flex;}
.spin{width:32px;height:32px;border:2.5px solid var(--bg3);border-top-color:var(--accent);border-radius:50%;animation:sp .7s linear infinite;}
@keyframes sp{to{transform:rotate(360deg)}}
.loader-txt{font-size:0.82rem;font-weight:700;color:var(--text2);}
.toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%) translateY(70px);background:var(--bg3);color:var(--text);border:1px solid var(--border2);padding:10px 20px;border-radius:100px;font-size:0.83rem;font-weight:700;z-index:700;transition:transform .3s cubic-bezier(.34,1.56,.64,1);white-space:nowrap;box-shadow:0 4px 24px rgba(0,0,0,.4);pointer-events:none;}
.toast.show{transform:translateX(-50%) translateY(0);}
.empty{text-align:center;padding:36px 20px;color:var(--text3);}
.empty-icon{font-size:2rem;margin-bottom:8px;}
.empty p{font-size:0.83rem;font-weight:600;}
</style>
</head>
<body>
<div class="loader" id="loader"><div class="spin"></div><div class="loader-txt" id="loaderTxt">Cargando...</div></div>
<div class="toast" id="toast"></div>

<div class="splash" id="splash">
  <div class="splash-ring">🦷</div>
  <div class="splash-title">¡Hola, Catalina!</div>
  <div class="splash-sub">Mia menea la colita y te desea el mejor turno 🐾🐶</div>
  <div class="splash-year">2026 · Pistacho 🌿</div>
  <button class="splash-btn" id="btnEntrar">Entrar a la app ✨</button>
</div>

<div class="header">
  <div class="hdr-top">
    <div>
      <div class="hdr-title">🦷 Horas Extras · Catalina</div>
      <div class="hdr-sub" id="mesLabel">—</div>
    </div>
    <div class="sync" id="sync">● sync</div>
  </div>
  <div class="tabs">
    <div class="tab active" onclick="showP('ingresar',this)"><span class="ti">📅</span>Ingresar</div>
    <div class="tab" onclick="showP('registros',this)"><span class="ti">📋</span>Registros</div>
    <div class="tab" onclick="showP('resumen',this)"><span class="ti">📊</span>Resumen</div>
    <div class="tab" onclick="showP('historial',this)"><span class="ti">🗂</span>Historial</div>
    <div class="tab" onclick="showP('config',this)"><span class="ti">⚙️</span>Config</div>
  </div>
</div>

<div class="content">
<div id="panel-ingresar" class="panel active">
  <div class="frase" id="frase"></div>
  <div class="card">
    <div class="card-title">Selecciona el día</div>
    <div class="cal-hdr">
      <button class="cal-nav" onclick="chMes(-1)">‹</button>
      <span class="cal-month" id="calMes"></span>
      <button class="cal-nav" onclick="chMes(1)">›</button>
    </div>
    <div class="cal-grid" id="calGrid">
      <div class="cdn">Lu</div><div class="cdn">Ma</div><div class="cdn">Mi</div>
      <div class="cdn">Ju</div><div class="cdn">Vi</div><div class="cdn">Sá</div><div class="cdn">Do</div>
    </div>
  </div>
  <div class="card">
    <div class="card-title" id="formTitle">Elige un día del calendario</div>
    <div class="fg">
      <label class="fl">Centro de Salud</label>
      <select id="selCentro" onchange="calcH()">
        <option value="">— Seleccionar —</option>
        <option>CESFAM Quinta Bella</option>
        <option>CESFAM Recoleta</option>
        <option>SAR</option>
        <option>Hevia</option>
        <option>Petrinovic</option>
      </select>
    </div>
    <div class="fg">
      <label class="fl">Extensión</label>
      <div class="ext-row">
        <button class="ext-btn on" onclick="setExt('Extensión 1',this)">Extensión 1</button>
        <button class="ext-btn" onclick="setExt('Extensión 2',this)">Extensión 2</button>
        <button class="ext-btn" onclick="setExt('Extensión 3',this)">Extensión 3</button>
      </div>
    </div>
    <div class="fg">
      <div class="hdisplay">
        <div class="hnum" id="hnum">—</div>
        <div style="text-align:right">
          <div class="hmdia" id="hmdia">horas</div>
          <div class="hmtipo" id="hmtipo"></div>
        </div>
      </div>
    </div>
    <button class="btn btn-primary" onclick="guardar()">Guardar registro</button>
  </div>
</div>

<div id="panel-registros" class="panel">
  <div class="card">
    <div class="card-title" id="regTitle">Registros del mes</div>
    <div id="listaReg"></div>
  </div>
  <button class="btn btn-dark btn-mt" onclick="exportExcel()">📥 Exportar Excel</button>
</div>

<div id="panel-resumen" class="panel">
  <div class="total-hero" id="totalHero"></div>
  <div class="stat-row">
    <div class="stat"><div class="stat-num" id="sLV">0</div><div class="stat-lbl">Horas L–V</div></div>
    <div class="stat"><div class="stat-num" id="sSab">0</div><div class="stat-lbl">Horas Sáb</div></div>
  </div>
  <div class="card"><div class="card-title">Por centro</div><div id="centros"></div></div>
</div>

<div id="panel-historial" class="panel"><div id="historial"></div></div>

<div id="panel-config" class="panel">
  <div class="card">
    <div class="cfg-section">
      <div class="cfg-title">💰 Valor por hora <span class="cfg-tarifa-badge" id="tarifaBadge">manual</span></div>
      <div class="cfg-info" id="cfgInfoTarifa"></div>
      <div class="fg" style="margin-top:12px">
        <label class="fl">Lunes a Viernes ($)</label>
        <input type="number" id="cfgLV" min="0" placeholder="15355">
      </div>
      <div class="fg">
