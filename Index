<script>
const SCRIPT_URL='https://script.google.com/macros/s/AKfycbzBt4sJ4Hh1d7veGvt1iroi8reNFnmTt4ixc6lEn5dIb5lU8ToEhTgJf-tf5yX3-e0F/exec';
const LOCAL_KEY='hke_cata_data',CFG_KEY='hke_cata_cfg',LC='hke_cata_lc',LE='hke_cata_le';
const MESES=['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
const DC=['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
const DL=['domingo','lunes','martes','miércoles','jueves','viernes','sábado'];

/* ── TARIFAS 2026: LV=$15.355/h · Sáb=$18.426/h ── */
const TARIFAS=[{desde:'2026-01',hasta:'2026-12',lv:15355,sab:18426}];
function tarifaParaMes(mk){for(const t of TARIFAS){if(mk>=t.desde&&mk<=t.hasta)return{valorLV:t.lv,valorSab:t.sab};}return null;}
function tarifaParaFecha(f){const[y,m]=f.split('-');return tarifaParaMes(`${y}-${m}`)||{valorLV:cfg.valorLV,valorSab:cfg.valorSab};}

/* ── ESTADO ── */
let cfg={valorLV:15355,valorSab:18426,horasLJ:3,horasVS:4};
let allData={},dSel=null,extSel='Extensión 1';
let eIdx=null,eMes=null,eExtVal='Extensión 1';
let pElim=null,pMes=null,_modalBusy=false;
/* FIX: calV persiste — no se resetea al guardar */
let calV=new Date(),_calInited=false;
const hoy=new Date();
const mesA=`${hoy.getFullYear()}-${pad(hoy.getMonth()+1)}`;

/* ── HELPERS ── */
function pad(n){return String(n).padStart(2,'0');}
function dow(f){const[y,m,d]=f.split('-').map(Number);return new Date(y,m-1,d).getDay();}
function esSab(f){return dow(f)===6;}
function esVie(f){return dow(f)===5;}
function hDia(f){const d=dow(f);if(d===0)return 0;if(d===5||d===6)return cfg.horasVS;return cfg.horasLJ;}
function ffecha(f){const[y,m,d]=f.split('-');return `${+d} de ${MESES[+m-1]} ${y}`;}
function fmoney(n){return '$'+Math.round(n).toLocaleString('es-CL');}

/* ── FERIADOS CHILE ── */
function feriadosChile(y){
  const fer=new Set(),add=(m,d)=>fer.add(`${y}-${pad(m)}-${pad(d)}`);
  add(1,1);add(5,1);add(5,21);add(6,29);add(7,16);add(8,15);
  add(9,18);add(9,19);add(10,12);add(10,31);add(11,1);add(11,15);add(12,8);add(12,25);
  function easter(y){
    const a=y%19,b=Math.floor(y/100),c=y%100,d=Math.floor(b/4),e=b%4;
    const f2=Math.floor((b+8)/25),g=Math.floor((b-f2+1)/3);
    const h=(19*a+b-d-g+15)%30,i=Math.floor(c/4),k=c%4;
    const l=(32+2*e+2*i-h-k)%7,m2=Math.floor((a+11*h+22*l)/451);
    return new Date(y,Math.floor((h+l-7*m2+114)/31)-1,((h+l-7*m2+114)%31)+1);
  }
  const ep=easter(y);
  const mk=(d,off)=>{const x=new Date(d);x.setDate(d.getDate()+off);return `${x.getFullYear()}-${pad(x.getMonth()+1)}-${pad(x.getDate())}`;};
  fer.add(mk(ep,-2));fer.add(mk(ep,-1));fer.add(mk(ep,60));
  const spDay=new Date(y,5,29).getDay();
  if(spDay===6)fer.add(`${y}-06-28`);else if(spDay===0)fer.add(`${y}-06-30`);
  if(new Date(y,8,18).getDay()===5)add(9,20);
  return fer;
}
const FER_CACHE={};
function getFer(y){if(!FER_CACHE[y])FER_CACHE[y]=feriadosChile(y);return FER_CACHE[y];}
function esFer(f){const[y]=f.split('-');return getFer(+y).has(f);}

/* ── UI ── */
function toast(msg,ms=2400){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),ms);}
function showLoad(t){document.getElementById('loaderTxt').textContent=t||'Cargando...';document.getElementById('loader').classList.add('show');}
function hideLoad(){document.getElementById('loader').classList.remove('show');}
function setSync(s,t){const el=document.getElementById('sync');el.textContent=t;el.className='sync '+s;}

/* ── CONFIG ── */
function actualizarInfoTarifa(){
  const badge=document.getElementById('tarifaBadge'),info=document.getElementById('cfgInfoTarifa'),tv=tarifaParaMes(mesA);
  if(tv){
    badge.textContent='automático 2026';badge.style.background='rgba(52,211,153,.15)';badge.style.color='var(--success)';
    info.innerHTML=`<strong style="color:var(--success)">✓ Tarifa automática 2026 activa</strong><br>L–V: ${fmoney(tv.valorLV)}/h &nbsp;·&nbsp; Sábado: ${fmoney(tv.valorSab)}/h<br><span style="opacity:.7">Todo el año 2026 usa estos valores fijos. Los campos de abajo se aplicarán a partir de 2027.</span>`;
  }else{
    badge.textContent='manual';badge.style.background='';badge.style.color='';
    info.innerHTML=`Los valores ingresados aquí se aplican a 2027 en adelante.<br>Para 2026 los valores son automáticos: L–V $15.355/h · Sáb $18.426/h (todo el año).`;
  }
}
function loadCfg(){
  try{const r=localStorage.getItem(CFG_KEY);if(r)cfg={...cfg,...JSON.parse(r)};}catch(e){}
  document.getElementById('cfgLV').value=cfg.valorLV;
  document.getElementById('cfgSab').value=cfg.valorSab;
  document.getElementById('cfgLJ').value=cfg.horasLJ;
  document.getElementById('cfgVS').value=cfg.horasVS;
  actualizarInfoTarifa();
}
async function guardarCfg(){
  const a=+document.getElementById('cfgLV').value,b=+document.getElementById('cfgSab').value;
  const c=+document.getElementById('cfgLJ').value,d2=+document.getElementById('cfgVS').value;
  if(!a||!b||!c||!d2){toast('⚠️ Completa todos los campos');return;}
  cfg={...cfg,valorLV:a,valorSab:b,horasLJ:c,horasVS:d2};
  try{localStorage.setItem(CFG_KEY,JSON.stringify(cfg));}catch(e){}
  await saveDatos(false);actualizarInfoTarifa();
  const ok=document.getElementById('cfgOk');ok.style.display='block';setTimeout(()=>ok.style.display='none',3000);
  toast('✓ Configuración guardada');
}

/* ── EXTENSIÓN ── */
function setExt(v,btn){extSel=v;document.querySelectorAll('#panel-ingresar .ext-btn').forEach(b=>b.classList.toggle('on',b===btn));try{localStorage.setItem(LE,v);}catch(e){}}
function setExtEdit(v){eExtVal=v;['eExt1','eExt2','eExt3'].forEach((id,i)=>document.getElementById(id).classList.toggle('on',v===`Extensión ${i+1}`));}

/* ── LOCAL STORAGE ── */
function saveLocal(){try{localStorage.setItem(LOCAL_KEY,JSON.stringify({data:allData,ts:Date.now()}));}catch(e){}}

/* ── CARGA DATOS ── */
function cargarDatos(){
  showLoad('Cargando datos...');
  const cb='jcb_cata_'+Date.now();let scriptEl=null;
  window[cb]=function(p){
    try{if(p._config){cfg={...cfg,...p._config};delete p._config;loadCfg();}allData=mergeHistorico(p);setSync('ok','● sync');saveLocal();saveDatos(false);}catch(e){setSync('error','⚠ error');}
    hideLoad();renderAll();delete window[cb];if(scriptEl&&scriptEl.parentNode)scriptEl.parentNode.removeChild(scriptEl);
  };
  scriptEl=document.createElement('script');
  scriptEl.onerror=function(){
    setSync('error','⚠ offline');
    try{const r=localStorage.getItem(LOCAL_KEY);if(r){const p=JSON.parse(r);allData=mergeHistorico(p.data||p);}else{allData=mergeHistorico({});}}catch(e){allData=mergeHistorico({});}
    hideLoad();renderAll();delete window[cb];
  };
  scriptEl.src=SCRIPT_URL+'?callback='+cb+'&t='+Date.now();
  document.head.appendChild(scriptEl);
}

/* ── GUARDAR DATOS ── */
async function saveDatos(spin=true){
  if(spin)showLoad('Guardando...');setSync('saving','⟳ guardando');
  try{await fetch(SCRIPT_URL,{method:'POST',mode:'no-cors',body:JSON.stringify({...allData,_config:cfg}),headers:{'Content-Type':'text/plain'}});setSync('ok','● sync');saveLocal();}
  catch(e){setSync('error','⚠ error');saveLocal();}
  if(spin)hideLoad();
}

/* ── RENDER ALL — FIX: NO resetea calV ── */
function renderAll(){
  const[y,m]=mesA.split('-');
  document.getElementById('mesLabel').textContent=`${MESES[+m-1]} ${y}`;
  if(!_calInited){calV=new Date(+y,+m-1,1);_calInited=true;}
  renderCal();renderReg();renderRes();renderHist();
  try{
    const lc=localStorage.getItem(LC);if(lc)document.getElementById('selCentro').value=lc;
    const le=localStorage.getItem(LE);
    if(le){extSel=le;document.querySelectorAll('#panel-ingresar .ext-btn').forEach(b=>b.classList.toggle('on',b.textContent.trim()===le));}
  }catch(e){}
}

/* ── PANEL ── */
function showP(name,el){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById(`panel-${name}`).classList.add('active');el.classList.add('active');
  if(name==='registros')renderReg();
  if(name==='resumen')renderRes();
  if(name==='historial')renderHist();
}

/* ── CALENDARIO ── */
function renderCal(){
  const y=calV.getFullYear(),m=calV.getMonth();
  document.getElementById('calMes').textContent=`${MESES[m]} ${y}`;
  const fd=new Date(y,m,1).getDay(),offset=fd===0?6:fd-1,days=new Date(y,m+1,0).getDate();
  const grid=document.getElementById('calGrid');
  while(grid.children.length>7)grid.removeChild(grid.lastChild);
  const mk=`${y}-${pad(m+1)}`,regs=allData[mk]||[];
  const todayS=`${hoy.getFullYear()}-${pad(hoy.getMonth()+1)}-${pad(hoy.getDate())}`;
  for(let i=0;i<offset;i++){const e=document.createElement('div');e.className='cd empty';grid.appendChild(e);}
  for(let d=1;d<=days;d++){
    const f=`${y}-${pad(m+1)}-${pad(d)}`,dw=dow(f),fer=esFer(f);
    const el=document.createElement('div');el.className='cd';el.textContent=d;
    if(dw===0)el.classList.add('dom');else if(dw===6&&!fer)el.classList.add('sabado');
    if(fer)el.classList.add('feriado');
    if(f===todayS)el.classList.add('today');
    if(f===dSel)el.classList.add('selected');
    const reg=regs.find(r=>r.fecha===f);
    if(reg){
      el.classList.add('has-reg');
      const cn=reg.centro.toLowerCase().replace(/\s+/g,'').normalize('NFD').replace(/[\u0300-\u036f]/g,'');
      if(cn.includes('quintabella'))el.classList.add('c-quinta');
      else if(cn.includes('recoleta'))el.classList.add('c-recoleta');
      else if(cn.includes('sar'))el.classList.add('c-sar');
      else if(cn.includes('hevia'))el.classList.add('c-hevia');
      else if(cn.includes('petrinovic'))el.classList.add('c-petrinovic');
    }
    if(dw!==0&&!fer)el.onclick=()=>selDia(f);
    grid.appendChild(el);
  }
}
function chMes(d){calV.setMonth(calV.getMonth()+d);renderCal();}
function selDia(f){
  dSel=f;const dw=dow(f);
  document.getElementById('formTitle').textContent=DL[dw].charAt(0).toUpperCase()+DL[dw].slice(1)+', '+ffecha(f);
  calcH();renderCal();
}

/* ── CALCULAR HORAS — distingue L–J / Viernes / Sábado ── */
function calcH(){
  if(!dSel)return;
  const h=hDia(dSel);
  document.getElementById('hnum').textContent=h||'—';
  document.getElementById('hmdia').textContent=h?'horas':'sin horas';
  const tp=document.getElementById('hmtipo'),tf=tarifaParaFecha(dSel);
  if(esSab(dSel)){tp.textContent=`Sábado · ${fmoney(tf.valorSab)}/h`;tp.className='hmtipo sat';}
  else if(esVie(dSel)){tp.textContent=`Viernes · ${fmoney(tf.valorLV)}/h`;tp.className='hmtipo vie';}
  else{tp.textContent=`Lunes – Jueves · ${fmoney(tf.valorLV)}/h`;tp.className='hmtipo';}
}

/* ── GUARDAR REGISTRO ── */
async function guardar(){
  if(!dSel){toast('⚠️ Selecciona un día');return;}
  const c=document.getElementById('selCentro').value;
  if(!c){toast('⚠️ Selecciona un centro');return;}
  if(esFer(dSel)){toast('🚫 Día feriado');return;}
  const h=hDia(dSel);if(h===0){toast('🚫 No hay horas el domingo');return;}
  const[dy,dm]=dSel.split('-'),mk=`${dy}-${dm}`;
  if(!allData[mk])allData[mk]=[];
  if(allData[mk].find(r=>r.fecha===dSel)&&!confirm('Ya existe un registro. ¿Reemplazar?'))return;
  allData[mk]=allData[mk].filter(r=>r.fecha!==dSel);
  try{localStorage.setItem(LC,c);}catch(e){}
  const tf=tarifaParaFecha(dSel);
  allData[mk].push({fecha:dSel,centro:c,extension:extSel,horas:h,altaTarifa:esSab(dSel),valorLV:tf.valorLV,valorSab:tf.valorSab});
  allData[mk].sort((a,b)=>a.fecha.localeCompare(b.fecha));
  await saveDatos();
  toast('✓ Registro guardado 🐶');
  dSel=null;
  document.getElementById('formTitle').textContent='Elige un día del calendario';
  document.getElementById('hnum').textContent='—';
  document.getElementById('hmdia').textContent='horas';
  document.getElementById('hmtipo').textContent='';
  renderAll();
}

/* ── RENDER REGISTROS ── */
function renderReg(){
  const regs=allData[mesA]||[],cont=document.getElementById('listaReg');
  const[y,m]=mesA.split('-');
  document.getElementById('regTitle').textContent=`${MESES[+m-1]} ${y}`;
  if(!regs.length){cont.innerHTML='<div class="empty"><div class="empty-icon">📋</div><p>Sin registros este mes</p></div>';return;}
  cont.innerHTML=regs.map((r,i)=>{
    const sat=esSab(r.fecha),vie=esVie(r.fecha);
    const v=sat?(r.valorSab||cfg.valorSab):(r.valorLV||cfg.valorLV);
    return `<div class="ri"><div class="ri-row"><div>
<div class="ri-date">${DC[dow(r.fecha)]} ${ffecha(r.fecha)}</div>
<div class="ri-meta"><span class="ri-centro">${r.centro}</span><span class="badge">${r.extension||'Ext 1'}</span>${sat?'<span class="badge sat">Sáb</span>':''}${vie?'<span class="badge vie">Vie</span>':''}</div>
</div><div class="ri-right"><div class="ri-horas">${r.horas}h</div><div class="ri-monto">${fmoney(r.horas*v)}</div></div></div>
<div class="ri-actions">
<button class="btn btn-ghost" data-a="edit" data-i="${i}" data-m="${mesA}">✏️ Editar</button>
<button class="btn btn-danger" data-a="del" data-i="${i}" data-m="${mesA}">Eliminar</button>
</div></div>`;
  }).join('');
  attachBtn(cont);
}

/* ── ATTACH BUTTONS — FIX: sin doble-fire touch/click ── */
function attachBtn(cont){
  cont.querySelectorAll('[data-a]').forEach(btn=>{
    let isTouched=false,fired=false;
    const handler=e=>{
      e.preventDefault();e.stopPropagation();
      if(fired)return;fired=true;
      const a=btn.dataset.a,i=+btn.dataset.i,m=btn.dataset.m;
      if(a==='edit')abrirEdit(i,m);if(a==='del')pedirElim(i,m);
    };
    btn.addEventListener('touchstart',()=>{isTouched=true;},{passive:true});
    btn.addEventListener('touchend',e=>{if(!isTouched)return;isTouched=false;handler(e);},{passive:false});
    btn.addEventListener('click',e=>{if(isTouched){isTouched=false;return;}handler(e);});
  });
}

/* ── ELIMINAR — FIX: cierra overlay antes de ejecutar ── */
function pedirElim(i,m){pElim={i,m};document.getElementById('ovEliminar').classList.add('open');}
function cxEliminar(){pElim=null;document.getElementById('ovEliminar').classList.remove('open');}
async function confElim(){
  if(_modalBusy)return;_modalBusy=true;
  document.getElementById('ovEliminar').classList.remove('open');
  await new Promise(r=>setTimeout(r,80));_modalBusy=false;
  if(!pElim)return;const{i,m}=pElim;pElim=null;
  allData[m].splice(i,1);if(!allData[m].length)delete allData[m];
  await saveDatos();toast('✓ Eliminado');renderAll();
}

/* ── EDITAR ── */
function abrirEdit(i,m){
  eIdx=i;eMes=m;const r=allData[m][i];
  document.getElementById('editFecha').textContent=DL[dow(r.fecha)].charAt(0).toUpperCase()+DL[dow(r.fecha)].slice(1)+', '+ffecha(r.fecha);
  document.getElementById('editCentro').value=r.centro;
  eExtVal=r.extension||'Extensión 1';
  ['eExt1','eExt2','eExt3'].forEach((id,j)=>document.getElementById(id).classList.toggle('on',eExtVal===`Extensión ${j+1}`));
  document.getElementById('ovEditar').classList.add('open');
}
function cxEditar(){eIdx=null;eMes=null;document.getElementById('ovEditar').classList.remove('open');}
async function confEditar(){
  if(_modalBusy)return;_modalBusy=true;
  if(eIdx===null||!eMes){_modalBusy=false;return;}
  const c=document.getElementById('editCentro').value;
  if(!c){toast('⚠️ Selecciona un centro');_modalBusy=false;return;}
  allData[eMes][eIdx].centro=c;allData[eMes][eIdx].extension=eExtVal;
  cxEditar();await new Promise(r=>setTimeout(r,80));_modalBusy=false;
  await saveDatos();toast('✓ Guardado');renderAll();
}

/* ── RESUMEN ── */
function renderRes(){
  const regs=allData[mesA]||[];
  const tLV=regs.filter(r=>!esSab(r.fecha)).reduce((s,r)=>s+r.horas,0);
  const tSab=regs.filter(r=>esSab(r.fecha)).reduce((s,r)=>s+r.horas,0);
  document.getElementById('sLV').textContent=tLV;
  document.getElementById('sSab').textContent=tSab;
  const bruto=regs.reduce((s,r)=>{const v=esSab(r.fecha)?(r.valorSab||cfg.valorSab):(r.valorLV||cfg.valorLV);return s+r.horas*v;},0);
  document.getElementById('totalHero').innerHTML=`<div class="th-lbl">Total del mes</div><div class="th-amt">${fmoney(bruto)}</div><div class="th-detail">${tLV}h L–V · ${tSab}h Sáb · ${regs.length} turno${regs.length!==1?'s':''}</div>`;
  const cs={};
  regs.forEach(r=>{
    if(!cs[r.centro])cs[r.centro]={lv:0,sab:0,mLV:0,mSab:0};
    const vL=r.valorLV||cfg.valorLV,vS=r.valorSab||cfg.valorSab;
    if(esSab(r.fecha)){cs[r.centro].sab+=r.horas;cs[r.centro].mSab+=r.horas*vS;}
    else{cs[r.centro].lv+=r.horas;cs[r.centro].mLV+=r.horas*vL;}
  });
  const maxH=Math.max(...Object.values(cs).map(c=>c.lv+c.sab),1);
  document.getElementById('centros').innerHTML=Object.entries(cs).map(([n,c])=>{
    const t=c.lv+c.sab,mo=c.mLV+c.mSab,p=[];
    if(c.lv>0)p.push(`${c.lv}h L–V`);if(c.sab>0)p.push(`${c.sab}h Sáb`);
    return `<div class="cb"><div class="cb-row"><span class="cb-name">${n}</span><span class="cb-amt">${fmoney(mo)}</span></div><div class="cb-sub">${p.join(' · ')}</div><div class="bar-bg"><div class="bar-fill" style="width:${(t/maxH*100).toFixed(0)}%"></div></div></div>`;
  }).join('')||'<p style="color:var(--text3);font-size:.83rem;font-weight:600">Sin registros</p>';
}

/* ── HISTORIAL ── */
function renderHist(){
  const cont=document.getElementById('historial');
  const meses=Object.keys(allData).sort().reverse();
  if(!meses.length){cont.innerHTML='<div class="empty"><div class="empty-icon">🗂</div><p>Sin historial aún</p></div>';return;}
  cont.innerHTML=meses.map(mk=>{
    const[y,m]=mk.split('-'),regs=allData[mk]||[],esMes=mk===mesA;
    const tH=regs.reduce((s,r)=>s+r.horas,0);
    const bruto=regs.reduce((s,r)=>{const v=esSab(r.fecha)?(r.valorSab||cfg.valorSab):(r.valorLV||cfg.valorLV);return s+r.horas*v;},0);
    const mini=regs.map(r=>{
      const sat=esSab(r.fecha),vie=esVie(r.fecha);
      return `<div class="ri" style="padding:10px 0"><div class="ri-row"><div><div class="ri-date" style="font-size:.8rem">${DC[dow(r.fecha)]} ${ffecha(r.fecha)}</div><div class="ri-meta"><span class="ri-centro">${r.centro}</span><span class="badge">${r.extension||'Ext 1'}</span>${sat?'<span class="badge sat">Sáb</span>':''}${vie?'<span class="badge vie">Vie</span>':''}</div></div><div class="ri-horas" style="font-size:1.05rem">${r.horas}h</div></div></div>`;
    }).join('');
    return `<div class="mes"><div class="mes-hdr" onclick="togMes('${mk}')"><div><div class="mes-nombre">${MESES[+m-1]} ${y}${esMes?' <span style="color:var(--accent);font-size:.7rem;font-weight:600">actual</span>':''}</div><div class="mes-stats">${regs.length} turno${regs.length!==1?'s':''} · ${tH}h · ${fmoney(bruto)}</div></div><span class="mes-chev" id="chev-${mk}">▾</span></div>
      <div class="mes-body" id="mb-${mk}">${mini||'<p style="color:var(--text3);font-size:.8rem;padding:10px 0;font-weight:600">Sin registros</p>'}<div class="mes-acts"><button class="btn btn-dark btn-sm" onclick="exportExcelMes('${mk}')">📥 Excel</button>${!esMes?`<button class="btn btn-danger btn-sm" onclick="pedirMes('${mk}')">🗑 Borrar</button>`:''}</div></div></div>`;
  }).join('');
}
function togMes(mk){document.getElementById(`mb-${mk}`).classList.toggle('open');document.getElementById(`chev-${mk}`).classList.toggle('open');}
function pedirMes(mk){pMes=mk;const[y,m]=mk.split('-');document.getElementById('ovMesTxt').textContent=`¿Eliminar todos los datos de ${MESES[+m-1]} ${y}?`;document.getElementById('ovMes').classList.add('open');}
function cxMes(){pMes=null;document.getElementById('ovMes').classList.remove('open');}
async function confMes(){
  if(_modalBusy)return;_modalBusy=true;
  document.getElementById('ovMes').classList.remove('open');
  await new Promise(r=>setTimeout(r,80));_modalBusy=false;
  if(!pMes)return;const mk=pMes;pMes=null;
  delete allData[mk];await saveDatos();toast('✓ Mes eliminado');renderHist();
}

/* ── EXPORT EXCEL ── */
function exportExcel(){exportExcelMes(mesA);}
function exportExcelMes(mk){
  const regs=allData[mk]||[];
  if(!regs.length){toast('⚠ Sin registros para exportar');return;}
  const DX=['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
  const[y,m]=mk.split('-');
  const rows=regs.map((r,i)=>{
    const v=esSab(r.fecha)?(r.valorSab||cfg.valorSab):(r.valorLV||cfg.valorLV);
    return{'#':i+1,'Fecha':r.fecha,'Día':DX[dow(r.fecha)],'Centro':r.centro,'Extensión':r.extension||'Extensión 1','Tipo':esSab(r.fecha)?'Sáb':esVie(r.fecha)?'Vie':'L–J','Horas':r.horas,'$/hora':v,'Total':Math.round(r.horas*v)};
  });
  const tH=regs.reduce((s,r)=>s+r.horas,0);
  const bruto=regs.reduce((s,r)=>{const v=esSab(r.fecha)?(r.valorSab||cfg.valorSab):(r.valorLV||cfg.valorLV);return s+r.horas*v;},0);
  rows.push({'#':'','Fecha':'','Día':'','Centro':'','Extensión':'','Tipo':'TOTAL','Horas':tH,'$/hora':'','Total':Math.round(bruto)});
  const cs={};
  regs.forEach(r=>{
    if(!cs[r.centro])cs[r.centro]={lv:0,sab:0,mLV:0,mSab:0};
    const vL=r.valorLV||cfg.valorLV,vS=r.valorSab||cfg.valorSab;
    if(esSab(r.fecha)){cs[r.centro].sab+=r.horas;cs[r.centro].mSab+=r.horas*vS;}
    else{cs[r.centro].lv+=r.horas;cs[r.centro].mLV+=r.horas*vL;}
  });
  const tLV=regs.filter(r=>!esSab(r.fecha)).reduce((s,r)=>s+r.horas,0);
  const tSab=regs.filter(r=>esSab(r.fecha)).reduce((s,r)=>s+r.horas,0);
  const res=Object.entries(cs).map(([n,c])=>({'Centro':n,'Horas L-V':c.lv,'Monto L-V':Math.round(c.mLV),'Horas Sáb':c.sab,'Monto Sáb':Math.round(c.mSab),'Total horas':c.lv+c.sab,'Total':Math.round(c.mLV+c.mSab)}));
  res.push({'Centro':'TOTAL','Horas L-V':tLV,'Monto L-V':Math.round(regs.filter(r=>!esSab(r.fecha)).reduce((s,r)=>s+r.horas*(r.valorLV||cfg.valorLV),0)),'Horas Sáb':tSab,'Monto Sáb':Math.round(regs.filter(r=>esSab(r.fecha)).reduce((s,r)=>s+r.horas*(r.valorSab||cfg.valorSab),0)),'Total horas':tLV+tSab,'Total':Math.round(bruto)});
  const wb=XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb,XLSX.utils.json_to_sheet(rows),'Registros');
  XLSX.utils.book_append_sheet(wb,XLSX.utils.json_to_sheet(res),'Por Centro');
  XLSX.writeFile(wb,`HorasExtras_${MESES[+m-1]}_${y}_Catalina.xlsx`);
  toast('📥 Excel descargado');
}

