/* ── MERGE — FIX: sanitiza claves sucias del servidor ── */
function mergeHistorico(serverData){
  const merged={};
  for(const[k,v]of Object.entries(serverData||{})){
    if(/^\d{4}-\d{2}$/.test(k)&&Array.isArray(v))merged[k]=v;
  }
  for(const[mk,regs]of Object.entries(DATOS_HISTORICOS)){
    if(!merged[mk]){merged[mk]=regs.slice();}
    else{
      const ex=new Set(merged[mk].map(r=>r.fecha));
      for(const r of regs){if(!ex.has(r.fecha))merged[mk].push(r);}
      merged[mk].sort((a,b)=>a.fecha.localeCompare(b.fecha));
    }
  }
  return merged;
}

